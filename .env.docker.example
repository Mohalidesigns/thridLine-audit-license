# Copy to .env and fill in. Generate secrets with:
#   APP_KEY:     php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
#   DB_PASSWORD: openssl rand -hex 24
# The .env file is gitignored — never commit real secrets.

APP_NAME="ThirdLine Licensing"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8088
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=thirdline_license
DB_USERNAME=license
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

LICENSE_ISSUER=thirdline-grc-licensing
